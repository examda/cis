✅ EXPERIMENT 10A – DIFFIE HELLMAN
#include<stdio.h>
#include<stdlib.h>

long long int power(int a,int b,int mod)
{
    long long int result=1;
    while(b>0)
    {
        if(b%2==1)
            result=(result*a)%mod;
        a=(a*a)%mod;
        b=b/2;
    }
    return result;
}

int main()
{
    int p,g,a,b,A,B,keyA,keyB;

    printf("Enter prime p: ");
    scanf("%d",&p);

    printf("Enter base g: ");
    scanf("%d",&g);

    printf("Enter private key a: ");
    scanf("%d",&a);

    printf("Enter private key b: ");
    scanf("%d",&b);

    A=power(g,a,p);
    B=power(g,b,p);

    keyA=power(B,a,p);
    keyB=power(A,b,p);

    printf("Shared key (A): %d\n",keyA);
    printf("Shared key (B): %d\n",keyB);

    return 0;
}
