#include <stdio.h>
#include <string.h>
#include <openssl/md5.h>

int main() {
    char input[1000];
    unsigned char digest[MD5_DIGEST_LENGTH];

    printf("Enter the message: ");
    scanf("%s", input);

    // Generate MD5 hash
    MD5((unsigned char*)input, strlen(input), digest);

    // Print hash
    printf("MD5 Hash: ");
    for(int i = 0; i < MD5_DIGEST_LENGTH; i++) {
        printf("%02x", digest[i]);
    }

    printf("\n");
    return 0;
}




